# Supply Chain Ghost — Environment Configuration
# Copy to .env and fill in values after CDK deployment

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# Cognito (populated by CDK outputs)
REACT_APP_USER_POOL_ID=
REACT_APP_USER_POOL_CLIENT_ID=

# API Gateway (populated by CDK outputs)
REACT_APP_API_URL=

# S3 Buckets (auto-created by CDK)
SCG_RAW_SIGNALS_BUCKET=scg-raw-signals
SCG_KB_BUCKET=scg-knowledge-base
SCG_AUDIT_BUCKET=scg-audit-trail
SCG_DASHBOARD_BUCKET=scg-dashboard-assets

# DynamoDB Tables (auto-created by CDK)
SCG_SIGNALS_TABLE=SCG_Signals
SCG_RISKS_TABLE=SCG_RiskAssessments
SCG_SUPPLIERS_TABLE=SCG_Suppliers

# Amazon Nova Models
NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
NOVA_PREMIER_MODEL_ID=amazon.nova-premier-v1:0

# Nova Act (ERP Automation)
NOVA_ACT_API_KEY=
ERP_URL=https://your-erp-system.example.com
ERP_USERNAME=
ERP_PASSWORD=

# Admin User
ADMIN_EMAIL=admin@supplychain-ghost.com
ADMIN_PASS=
